# Copia este archivo a .env y completa los valores.
# NO commitees .env al repo.

# Clave para firmar las cookies de sesion. Genera una con:
#   openssl rand -hex 32
ARGOS_SESSION_SECRET=

# Clave maestra para cifrar secretos en la DB (tokens de bot Telegram,
# passwords SMTP, headers de webhook, VAPID privada, etc). AES-GCM
# requiere 32 bytes; exactamente 64 hex. Genera con:
#   openssl rand -hex 32
# PERDER esta clave = perder acceso a TODOS los secretos cifrados.
# Rotarla requiere re-crear los channels.
ARGOS_MASTER_KEY=

# Usuario admin inicial que se crea la primera vez que arranca el panel.
# Si el usuario ya existe en la DB, estos valores se ignoran.
ARGOS_INITIAL_ADMIN_USER=admin
ARGOS_INITIAL_ADMIN_PASSWORD=

# -------- Phase 9b: Panel access mode --------
# lan (default): HTTP on 0.0.0.0:8080, cookies non-Secure, no HSTS,
#                no CSP. Panel reachable at http://<lan-ip>:8080.
# behind_caddy:  panel runs behind the Argos-owned Caddy under
#                ARGOS_PANEL_DOMAIN; cookies Secure+SameSite=Strict,
#                HSTS + CSP headers added, :8080 is NOT published to
#                the host, and the panel bootstraps a hosts row for
#                itself on first boot. Layer the override compose:
#                  docker compose -f docker-compose.yml \
#                                 -f docker-compose.behind-caddy.yml up -d
ARGOS_PANEL_MODE=lan
ARGOS_PANEL_DOMAIN=

# BREAKING CHANGE (v0.9.0): ARGOS_COOKIE_SECURE was removed. Cookie
# Secure flag is now derived from ARGOS_PANEL_MODE. If you previously
# set ARGOS_COOKIE_SECURE=true, switch to ARGOS_PANEL_MODE=behind_caddy.

# -------- Phase 9b: Resource limits --------
# Tune if the panel handles more hosts / more log volume. Defaults
# are conservative for a homelab LXC with 1-2 GiB RAM.
ARGOS_MEM_LIMIT=512m
ARGOS_CPU_LIMIT=1.0
CADDY_MEM_LIMIT=256m
CADDY_CPU_LIMIT=0.5
