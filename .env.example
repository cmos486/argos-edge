# Copia este archivo a .env y completa los valores.
# NO commitees .env al repo.

# Clave para firmar las cookies de sesion. Genera una con:
#   openssl rand -hex 32
ARGOS_SESSION_SECRET=

# Clave maestra para cifrar secretos en la DB (tokens de bot Telegram,
# passwords SMTP, headers de webhook, VAPID privada, etc). AES-GCM
# requiere 32 bytes; exactamente 64 hex. Genera con:
#   openssl rand -hex 32
# PERDER esta clave = perder acceso a TODOS los secretos cifrados.
# Rotarla requiere re-crear los channels.
ARGOS_MASTER_KEY=

# Usuario admin inicial que se crea la primera vez que arranca el panel.
# Si el usuario ya existe en la DB, estos valores se ignoran.
ARGOS_INITIAL_ADMIN_USER=admin
ARGOS_INITIAL_ADMIN_PASSWORD=
