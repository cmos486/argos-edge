# Capture session env. Copy to .env and fill in.
# .env is gitignored; never commit real values.
#
# ARGOS_PROD_URL  -- the panel base URL (e.g. https://argos.example.com).
# ARGOS_PROD_USER -- admin username for the capture session.
# ARGOS_PROD_PASS -- password for that user.
#
# Optional:
# ARGOS_OUTPUT_DIR -- override /tmp/argos-captures-pending/ if needed.
# ARGOS_KEEP_BROWSER -- "1" leaves the browser open at end of run for
#                      manual capture of skip-list surfaces.

ARGOS_PROD_URL=https://argos.example.com
ARGOS_PROD_USER=admin
ARGOS_PROD_PASS=
